generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Product {
  id           Int            @id
  name         String
  category     String
  unit         String
  description  String?
  active       Boolean        @default(true)
  createdAt    DateTime       @default(now())
  priceRecords PriceRecord[]
  marketFactors MarketFactor[]
}

model Market {
  id            Int            @id
  name          String
  city          String
  state         String
  channel       String
  active        Boolean        @default(true)
  createdAt     DateTime       @default(now())
  priceRecords  PriceRecord[]
  marketFactors MarketFactor[]
}

model PriceRecord {
  id         Int      @id @default(autoincrement())
  productId  Int
  marketId   Int
  price      Float
  freight    Float
  totalPrice Float
  collectedAt DateTime
  source     String   @default("seed")
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  market     Market   @relation(fields: [marketId], references: [id], onDelete: Cascade)

  @@unique([productId, marketId, collectedAt])
  @@index([productId, collectedAt])
  @@index([marketId, collectedAt])
}

model MarketFactor {
  id          Int      @id @default(autoincrement())
  productId   Int
  marketId    Int
  title       String
  description String
  direction   String
  intensity   Int
  collectedAt DateTime
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  market      Market   @relation(fields: [marketId], references: [id], onDelete: Cascade)

  @@index([productId, collectedAt])
}
